{
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "dev:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "dev:backend": "python ./backend/app_web.py",
    "files:auto-sort": "powershell -ExecutionPolicy Bypass -File ./scripts/start-auto-sort.ps1",
    "build:auto-sort-exe": "powershell -ExecutionPolicy Bypass -File ./scripts/build-auto-sort-exe.ps1",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite",
    "locations:sync": "node ./backend/scripts/sync-locations.mjs",
    "firestore:list": "node ./backend/scripts/firestore-tools.mjs list",
    "firestore:get:company": "node ./backend/scripts/firestore-tools.mjs get Company",
    "admin:add": "powershell -ExecutionPolicy Bypass -File ./scripts/add-admin-user.ps1"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "vite": "^7.1.7"
  }
}
